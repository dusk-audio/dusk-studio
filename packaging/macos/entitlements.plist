<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- OOP plugin host loads third-party VST3/AU/CLAP bundles that
         aren't signed by the same team ID as Dusk Studio. Without this
         entitlement Hardened Runtime refuses to load them. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Required for AudioUnit host - JIT pages from inside hosted
         AU plugins (FaustAU, MaxForLive, JUCE-AU wrappers) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Mic / audio input access for recording. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- User opens .dusksession files via Finder. -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Allow reading bundled plugins outside the app's sandbox
         (sibling /Library/Audio/Plug-Ins paths). -->
    <key>com.apple.security.files.absolute-path.read-only</key>
    <true/>
</dict>
</plist>
